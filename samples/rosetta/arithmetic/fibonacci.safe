package Fibonacci is

   type Count is range 1 to 12;
   type Value is range 0 to 10_000;

   function Nth (N : Count) returns Value is
      Previous : Value = 0;
      Current  : Value = 1;
      Next     : Value = 0;
   begin
      if N == 1 then
         return 0;
      end if;

      for Step in 2 to N loop
         Next = Previous + Current;
         Previous = Current;
         Current = Next;
      end loop;

      return Current;
   end Nth;

end Fibonacci;
