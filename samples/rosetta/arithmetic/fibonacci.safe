package fibonacci

   type count is range 1 to 12;
   type value is range 0 to 10_000;

   function nth (n : count) returns value

      var previous : value = 0
      var current  : value = 1
      var next     : value = 0
      if n == 1
         return 0


      for step in 2 to n
         next = previous + current
         previous = current
         current = next


      return current



