package Gcd

   type Input_Value is range 1 to 10_000;
   type Working_Value is range 0 to 10_000;
   type Iteration is range 1 to 32;

   function Compute (Left : Input_Value; Right : Input_Value) returns Working_Value

      var A : Working_Value = Working_Value (Left)
      var B : Working_Value = Working_Value (Right)
      var T : Working_Value = 0
      for Step in Iteration
         if B == 0
            return A

         T = A rem B
         A = B
         B = T


      return A



