package Factorial is

   type Count is range 0 to 7;
   type Value is range 1 to 1_000_000;

   function Compute (N : Count) returns Value is
      Product : Value = 1;
   begin
      if N == 0 then
         return 1;
      end if;

      for I in 1 to N loop
         Product = Product * Value (I);
      end loop;

      return Product;
   end Compute;

end Factorial;
