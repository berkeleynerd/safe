package Lookup_Pair is

   function Find_Code (Opcode : in Integer) returns (Boolean, Integer) is
   begin
      case Opcode is
         when 1 then
            return (True, 10);
         end when;
         when 2 then
            return (True, 20);
         end when;
         when others then
            return (False, 0);
         end when;
      end case;
   end Find_Code;

end Lookup_Pair;
