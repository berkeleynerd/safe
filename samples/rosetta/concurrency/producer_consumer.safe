package Producer_Consumer is

   type Message is range 0 to 1000;

   channel Data_Ch : Message capacity 1;
   Result : Message = 0;

   task Producer with Priority = 10 is
   begin
      loop
         send Data_Ch, 41;
         delay 0.05;
      end loop;
   end Producer;

   task Consumer with Priority = 10 is
      Input : Message;
   begin
      loop
         receive Data_Ch, Input;
         Result = Input + 1;
      end loop;
   end Consumer;

end Producer_Consumer;
