package producer_consumer

   type message is range 0 to 1000;

   channel data_ch : message capacity 1;
   result : message = 0;

   task producer with priority = 10

      loop
         send data_ch, 41
         delay 0.05

   task consumer with priority = 10

      loop
         var input : message
         receive data_ch, input
         result = input + 1

