{
  "name": "Safe",
  "scopeName": "source.safe",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#invalid_uppercase"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#tuple_selectors"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.safe",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.safe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.safe",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "constant.character.safe",
          "match": "'(?:''|[^'])'"
        }
      ]
    },
    "invalid_uppercase": {
      "patterns": [
        {
          "name": "invalid.illegal.safe",
          "match": "(?<![#\\w])(?=[A-Za-z_]*[A-Z])[A-Za-z][A-Za-z0-9_]*\\b(?!#)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "invalid.deprecated.safe",
          "match": "\\b(begin|end|then|access|new|try_send|out|in\\s+out)\\b"
        },
        {
          "name": "keyword.control.safe",
          "match": "\\b(package|public|is|if|else|loop|while|for|return|returns|record|type|subtype|range|to|function|task|channel|capacity|from|send|receive|try_receive|sends|receives|select|delay|with|constant|var|null|and|or|xor|not|mod|rem|case|when|others|exit|digits|binary|print|try|match|optional|list|map|of|interface|shared|mut)\\b"
        },
        {
          "name": "storage.modifier.safe",
          "match": "\\b(priority|pragma)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.safe",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.safe",
          "match": "\\b(boolean|integer|string|float|long_float|duration|result)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.safe",
          "match": "\\b(ok|fail|some|none|append|pop_last|contains|get|set|remove)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "support.function.attribute.safe",
          "match": "(?<!\\d)\\.(first|last|length|range|image|valid|present|value)\\b"
        }
      ]
    },
    "tuple_selectors": {
      "patterns": [
        {
          "name": "variable.other.member.tuple-index.safe",
          "match": "(?<!\\d)\\.\\d+\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.safe",
          "match": "\\b\\d[\\d_]*(?:\\.\\d[\\d_]*)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.safe",
          "match": "<<|>>|==|!=|<=|>=|[-+*/<>=&]"
        }
      ]
    }
  },
  "uuid": "a1dce541-4d59-44fd-93cb-0d86e4fc335f"
}
