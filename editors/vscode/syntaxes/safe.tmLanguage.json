{
  "name": "Safe",
  "scopeName": "source.safe",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#tuple_selectors"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.safe",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.safe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.safe",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "constant.character.safe",
          "match": "'(?:''|[^'])'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.safe",
          "match": "\\b(package|is|begin|end|if|else|then|loop|while|for|return|returns|record|type|range|to|access|function|task|channel|send|receive|try_send|try_receive|select|delay|new|with|constant|null|and|or|not|mod|rem|case|when|others)\\b"
        },
        {
          "name": "storage.modifier.safe",
          "match": "\\b(out|in|in\\s+out|Priority|pragma)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.safe",
          "match": "\\b(True|False)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.safe",
          "match": "\\b(Boolean|Integer|Natural|Character|String|result)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.safe",
          "match": "\\b(ok|fail)\\b"
        }
      ]
    },
    "tuple_selectors": {
      "patterns": [
        {
          "name": "variable.other.member.tuple-index.safe",
          "match": "(?<!\\d)\\.\\d+\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.safe",
          "match": "\\b\\d[\\d_]*(?:\\.\\d[\\d_]*)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.safe",
          "match": "==|!=|<=|>=|:=|=>|[-+*/<>=]"
        }
      ]
    }
  },
  "uuid": "a1dce541-4d59-44fd-93cb-0d86e4fc335f"
}
