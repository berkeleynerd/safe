package pr1123g_nested_iteration_build

   subtype factor is integer (0 to 6);

   function dot_product returns integer
      var xs : list of factor = [1, 2, 3]
      var ys : list of factor = [4, 5, 6]
      var total : integer = 0

      for x of xs
         for y of ys
            total = total + x * y

      return total

   print (dot_product)
