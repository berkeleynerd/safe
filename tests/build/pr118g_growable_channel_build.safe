package pr118g_growable_channel_build

   type values is array of integer

   channel data_ch : values capacity 1
   source : values = [1, 2]
   received : values
   sent : boolean = false

   send data_ch, source, sent
   if sent
      source = [9]
      receive data_ch, received

      print (received (1))
      print (received.length)
      print (source (1))
   else
      print (0)
      print (0)
      print (source (1))
