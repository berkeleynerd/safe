package pr1122f2_shared_optional_string_none_build

   type nested_state is record
      maybe : optional string;

   type settings is record
      maybe  : optional string;
      nested : nested_state;

   shared cfg : settings = (maybe = some ("hello"), nested = (maybe = some ("inner")));
   snap : settings;

   function clear_fields
      cfg.maybe = none;
      cfg.nested.maybe = none;

   clear_fields ();
   snap = cfg;
   if not snap.maybe.present and then not snap.nested.maybe.present
      print ("cleared");
   else
      print ("bad");
