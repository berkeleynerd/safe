package pr1112a_shared_task_build

   subtype counter is integer (0 to 20);

   type mode is (idle, ready);

   type nested_state is record
      depth : counter;

   type settings is record
      count  : counter;
      status : mode;
      label  : string (5);
      maybe  : optional counter;
      nested : nested_state;

   shared cfg : settings = (count = 0, status = idle, label = "hello", maybe = none, nested = (depth = 2));

   task worker with priority = 10
      maybe_now : optional counter;
      status_now : mode;
      count_now : counter;
      label_now : string (5);
      nested_now : nested_state;

      loop
         cfg.count = 4;
         cfg.status = ready;
         cfg.label = "world";
         cfg.maybe = some (counter (3));

         maybe_now = cfg.maybe;
         status_now = cfg.status;
         count_now = cfg.count;
         label_now = cfg.label;
         nested_now = cfg.nested;

         if maybe_now.present and then status_now == ready and then count_now == 4 and then label_now.length == 5 and then nested_now.depth == 2
            print (count_now);
            print (label_now.length);
            print (maybe_now.value);
            print (nested_now.depth);
            delay 1.0;
         else
            print (0);
            delay 0.01;
