-- Test: pr228_shared_field_condition_build
-- Description: Shared field reads in conditions must snapshot before proof-visible comparison.
-- Expected: BUILD_SUCCESS

type state is record
   total : integer
   ready : boolean
   note  : string (5)

shared ledger : state = (total = 1, ready = false, note = "stand")
snapshot : state = ledger
value : integer = 0

ledger.total = 8
ledger.ready = true
ledger.note = "again"

if ledger.total == 8 and then ledger.ready and then ledger.note == "again"
   snapshot = ledger
   if snapshot.total == 8 and then snapshot.ready and then snapshot.note == "again"
      value = 17

print (value)
