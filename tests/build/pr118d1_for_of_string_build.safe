package pr118d1_for_of_string_build

   plain : string = "Ada"
   short : string (2) = "hi"
   total : integer = 0

   for ch of plain
      if ch == "A" or ch == "d" or ch == "a"
         total = total + 1

   for ch of short
      if ch == "h" or ch == "i"
         total = total + 1

   print (total)
