   pr228_provider_shared_condition.cfg.total = 8;
   pr228_provider_shared_condition.cfg.ready = true;

   if pr228_provider_shared_condition.cfg.total == 8 and then pr228_provider_shared_condition.cfg.ready
      value = 17;

   print (value)
