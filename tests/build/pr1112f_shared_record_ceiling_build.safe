package pr1112f_shared_record_ceiling_build

   subtype counter is integer (0 to 2)

   type settings is record
      count : counter

   shared cfg : settings

   task fast with priority = 20
      done : boolean = false

      loop
         if not done
            cfg.count = 1
            print (20)
            done = true
         else
            delay 0.01

   task slow with priority = 10
      done : boolean = false

      loop
         if not done
            cfg.count = 2
            done = true
         else
            delay 0.01
