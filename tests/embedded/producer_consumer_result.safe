-- Test: producer_consumer_result
-- Description: Channel-based producer/consumer tasking reaches a stable shared result.
-- Expected embedded result: 42

package producer_consumer_result

   subtype message is integer (41 to 41)
   public subtype result_value is integer (0 to 42)

   channel data_ch : message capacity 1
   public channel result_ch : result_value capacity 1

   task producer with priority = 10, sends data_ch
      sent : boolean = false
      loop
         send data_ch, 41, sent
         if sent
            delay 0.05
         else
            delay 0.01

   task consumer with priority = 10, receives data_ch, sends result_ch
      sent : boolean = false
      loop
         receive data_ch, input : message
         loop
            send result_ch, result_value (input + 1), sent
            if sent
               exit
            delay 0.01
         delay 0.05
