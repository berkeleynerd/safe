-- Test: delay_scope_result
-- Description: Delay-arm locals remain scoped correctly under embedded tasking.
-- Expected embedded result: 2

package delay_scope_result

   subtype message is integer (0 to 10)
   subtype total_count is integer (0 to 2)
   public subtype result_value is total_count

   channel data_ch : message capacity 1
   public channel result_ch : result_value capacity 1

   task worker with priority = 10, sends result_ch
      sent : boolean = false
      loop
         select
            when item : message from data_ch
               loop
                  send result_ch, 0, sent
                  if sent
                     exit
                  delay 0.01
               delay 0.05
         or
            delay 0.01
               temp : integer = 1
               temp = temp + 1
               loop
                  send result_ch, total_count (temp), sent
                  if sent
                     exit
                  delay 0.01
               delay 0.05
