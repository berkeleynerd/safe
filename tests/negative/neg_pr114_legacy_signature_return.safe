-- Test: neg_pr114_legacy_signature_return
-- Description: PR11.4 requires returns in subprogram signatures and rejects legacy signature return.
-- Expected: REJECT source_frontend_error

package Neg_PR114_Legacy_Signature_Return is

   function Identity (Value : Integer) return Integer is
   begin
      return Value;
   end Identity;

end Neg_PR114_Legacy_Signature_Return;
