-- Test: neg_rule3_zero_rem
-- Description: Remainder by a variable that may be zero.
--   The divisor parameter includes zero in its type range.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.3.p133:0610d951
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.3.p134:90a17a3b
-- Expected: REJECT division_by_zero

package zero_rem_test

   subtype signed is integer (-50 to 50)

   --  Remainder_Unsafe: computes A rem B, but B may be zero.
   function remainder_unsafe (a, b : signed) returns signed

      return a rem b  -- ERROR: B may be zero

