-- Test: neg_rule4_uninitialized
-- Description: Dereference of an access variable that has no initial value.
--   The access variable's default value is null, and it is dereferenced
--   without being assigned a non-null value.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.4.p136:fa5e94b7
-- Expected: REJECT null_dereference

package Uninitialized_Test

   type Rec is record
      X : Integer;


   type Rec_Ptr is access Rec;

   --  Read_Uninitialized: declares P (default null), then dereferences.
   function Read_Uninitialized returns Integer
      P : Rec_Ptr;

      --  P is null (default for access types).
      return P.all.X;  -- ERROR: P is null (uninitialized = null)



