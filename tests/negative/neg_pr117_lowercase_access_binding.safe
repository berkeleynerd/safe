-- Test: neg_pr117_lowercase_access_binding
-- Description: Reference-signal naming requires access bindings to start uppercase.
-- Expected: REJECT source_frontend_error

package neg_pr117_lowercase_access_binding

   type payload is record
      value : integer;

   type payload_ptr is access payload;

   function demo returns integer
      owner : payload_ptr = new ((value = 1) as payload);

      return owner.value;
