-- Test: neg_send_use_after_move
-- Description: Access-typed channel elements are rejected before send ownership-transfer checks run.
-- Expected: REJECT source_frontend_error

package Neg_Send_Use_After_Move is

   type Payload is record
      Value : Integer;
   end record;

   type Payload_Ptr is access Payload;

   channel Data_Ch : Payload_Ptr capacity 1;

   function Run is
      Source : Payload_Ptr = new ((Value = 1) as Payload);
   begin
      send Data_Ch, Source;
      Source.all.Value = 2;
   end Run;

end Neg_Send_Use_After_Move;
