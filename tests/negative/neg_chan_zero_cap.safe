-- Test: neg_chan_zero_cap
-- Description: Declaring a channel with zero capacity.
--   The capacity must be at least 1. A capacity of 0 is rejected.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.2.p15:b5b29b0e
-- Expected: REJECT source_frontend_error

package zero_cap_test

   subtype msg is integer (0 to 255);

   --  Zero_Ch: capacity 0 violates the requirement that capacity >= 1.
   channel zero_ch : msg capacity 0;  -- ERROR: capacity must be >= 1

