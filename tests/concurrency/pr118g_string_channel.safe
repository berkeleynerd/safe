-- Test: pr118g_string_channel
-- Description: Direct string channel elements use value-copy semantics.
-- Expected: ACCEPT

package pr118g_string_channel

   channel text_ch : string capacity 1
   seed : string = "Ada"
   initial_sent : boolean = false

   task worker with priority = 10, sends text_ch, receives text_ch
      sent : boolean = false
      loop
         receive text_ch, value : string
         loop
            send text_ch, value, sent
            if sent
               exit
            delay 0.01
         delay 0.05

   send text_ch, seed, initial_sent
