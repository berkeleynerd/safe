-- Test: try_ops
-- Description: Non-owning try_send and try_receive operations.
--   Producer and consumer tasks use the non-blocking channel forms with a
--   Boolean success variable and relative delays on the retry path.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p25:961abe5a
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p29:f792d704
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p30:62619161
-- Expected: ACCEPT

package try_ops

   type item is range 0 to 100;

   channel data_ch : item capacity 2;

   task producer
      next : item = 0;
      sent : boolean = false;

      loop
         try_send data_ch, next, sent;
         if sent
            if next < 100
               next = next + 1;
            else
               next = 0;

         else
            delay 0.01;




   task consumer
      value : item = 0;
      got   : boolean = false;
      total : natural = 0;

      loop
         try_receive data_ch, value, got;
         if got
            total = total + natural (value);
         else
            delay 0.01;

         if total > 10_000
            total = 0;





