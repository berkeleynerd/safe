-- Test: try_ops
-- Description: Non-owning send and try_receive operations.
--   Producer and consumer tasks use the non-blocking channel forms with a
--   Boolean success variable and relative delays on the retry path.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p25:961abe5a
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p29:f792d704
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p30:62619161
-- Expected: ACCEPT

package try_ops

   subtype item is integer (0 to 100)
   subtype total_count is integer (0 to 10_000)

   channel data_ch : item capacity 2

   task producer with priority = 10
      next : item = 0
      sent : boolean

      loop
         send data_ch, next, sent
         if sent
            if next < 100
               next = next + 1
            else
               next = 0

         else
            delay 0.01

   task consumer with priority = 10
      value          : item = 0
      got            : boolean
      consumer_total : total_count = 0

      loop
         try_receive data_ch, value, got
         if got
            if consumer_total <= 10_000 - integer (value)
               consumer_total = consumer_total + integer (value)
            else
               consumer_total = 0
         else
            delay 0.01
