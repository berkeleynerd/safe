-- Test: task_global_owner
-- Description: One task reaches one package global through a local helper.
--   This is the minimal passing case for the local task/global ownership map
--   and the conservative Depends summary.
-- Expected: ACCEPT

package Task_Global_Owner

   type Counter is range 0 to 100;

   Shared : Counter = 0;

   function Bump

      Shared = Shared + 1;


   task Worker

      loop
         Bump;




