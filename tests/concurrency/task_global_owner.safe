-- Test: task_global_owner
-- Description: One task uses a local helper and task-local state only.
--   This keeps the helper-call path while satisfying the PR11.8e task-body
--   locals-plus-channels restriction.
-- Expected: ACCEPT

package task_global_owner

   subtype counter is integer (0 to 100)

   function bump (value : counter) returns counter

      if value < 100
         return value + 1
      else
         return 0

   task worker
      local_count : counter = 0

      loop
         local_count = bump (local_count)
