-- Test: multi_task_channel
-- Description: Multiple tasks communicating over a single channel.
--   Two producers send distinct scalar event codes to the same channel,
--   and one consumer receives them. Channel atomicity ensures no
--   corruption across same-channel operations.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p31:a7297e97
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p27:ef0ce6bd
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p28:ea6bd13c
-- Expected: ACCEPT

package multi_task_channel

   type event_code is range 0 to 10_000;

   channel event_ch : event_code capacity 8;

   --  Producer_A: sends low-range event codes.
   task producer_a
      seq : event_code = 0;

      loop
         send event_ch, seq;
         if seq < 4_999
            seq = seq + 1;
         else
            seq = 0;




   --  Producer_B: sends high-range event codes.
   task producer_b
      seq : event_code = 5_000;

      loop
         send event_ch, seq;
         if seq < 10_000
            seq = seq + 1;
         else
            seq = 5_000;




   --  Consumer: receives events from both producers.
   --  Channel atomicity guarantees each code is received intact.
   task consumer
      e : event_code = 0;
      count_a : natural = 0;
      count_b : natural = 0;

      loop
         receive event_ch, e;
         if e < 5_000
            count_a = count_a + 1;
         else
            count_b = count_b + 1;

         if count_a > 1_000
            count_a = 0;

         if count_b > 1_000
            count_b = 0;





