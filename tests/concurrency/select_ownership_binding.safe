-- Test: select_ownership_binding
-- Description: Access-typed channel elements are illegal, including in select arms.
--   The channel declaration is rejected before select-arm binding semantics apply.
-- Expected: REJECT source_frontend_error

package select_ownership_binding

   type payload is record
      value : integer

   type payload_ptr is access payload

   channel data_ch : payload_ptr capacity 1

   task sender
      counter : integer = 0
      sent : boolean = false

      loop
         item : payload_ptr = new ((value = counter) as payload)
         send data_ch, item, sent
         counter = counter + 1

   task receiver

      loop
         select
            when item : payload_ptr from data_ch
               item.all.value = item.all.value + 1
         or
            delay 1.0
