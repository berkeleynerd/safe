-- Test: pr118b1_scoped_try_receive
-- Description: Scoped try_receive bindings are default-initialized on the failure path.
-- Expected: ACCEPT

package pr118b1_scoped_try_receive

   subtype message is integer (0 to 10)

   channel data_ch : message capacity 1

   task consumer with priority = 10, receives data_ch
      observed : message = 0

      loop
         var got : boolean = false
         try_receive data_ch, item : message, got
         if got
            observed = item
         else
            observed = item
