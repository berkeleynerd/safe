-- Test: exclusive_variable
-- Description: Exclusive variable ownership across tasks.
--   Each variable is accessed by exactly one task. No variable
--   is shared between tasks, satisfying the task-variable ownership rule.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.5.p45:8bdd0c99
-- Clause: SAFE@468cf72:spec/05-assurance.md#5.4.1.p32:90d4f527
-- Clause: SAFE@468cf72:spec/05-assurance.md#5.4.1.p33:0fc25399
-- Expected: ACCEPT

package Exclusive_Variable is

   type Counter is range 0 .. 1_000_000;

   --  Each task has its own private counter variable.
   --  No variable is shared between Task_A and Task_B.

   channel Sync_Ch : Counter capacity 1;

   --  Task_A: owns Counter_A exclusively. Sends result via channel.
   task Task_A is
      Counter_A : Counter = 0;
   begin
      loop
         Counter_A = Counter_A + 1;
         if Counter_A >= 1000 then
            send Sync_Ch, Counter_A;
            Counter_A = 0;
         end if;
      end loop;
   end Task_A;

   --  Task_B: owns Counter_B exclusively. Receives via channel.
   task Task_B is
      Counter_B : Counter = 0;
      Received  : Counter;
   begin
      loop
         receive Sync_Ch, Received;
         Counter_B = Counter_B + Received;
         if Counter_B > 500_000 then
            Counter_B = 0;
         end if;
      end loop;
   end Task_B;

end Exclusive_Variable;
