-- Test: exclusive_variable
-- Description: Task-local variable state across tasks.
--   Each task keeps its mutable state local and communicates only through
--   channels, satisfying the PR11.8e task-body restriction.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.5.p45:8bdd0c99
-- Clause: SAFE@468cf72:spec/05-assurance.md#5.4.1.p32:90d4f527
-- Clause: SAFE@468cf72:spec/05-assurance.md#5.4.1.p33:0fc25399
-- Expected: ACCEPT

package exclusive_variable

   subtype counter is integer (0 to 1_000_000)

   channel sync_ch : counter capacity 1

   --  Task_A: owns Counter_A exclusively. Sends result via channel.
   task task_a with priority = 10
      counter_a : counter = 0
      sent : boolean = false

      loop
         if counter_a < 999
            counter_a = counter_a + 1
         else
            counter_a = 1_000
            send sync_ch, counter_a, sent
            if sent
               counter_a = 0

   --  Task_B: owns Counter_B exclusively. Receives via channel.
   task task_b with priority = 10
      received     : counter
      task_b_total : counter = 0

      loop
         receive sync_ch, received
         if task_b_total <= 1_000_000 - received
            task_b_total = task_b_total + received
         else
            task_b_total = 0
