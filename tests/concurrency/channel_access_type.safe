-- Test: channel_access_type
-- Description: Channel element types shall not be access types.
--   Access-typed channel declarations are rejected at the declaration site.
-- Expected: REJECT source_frontend_error

package Channel_Access_Type

   type Payload_Value is range 0 to 1;

   type Payload is record
      Value : Payload_Value;


   type Payload_Ptr is access Payload;

   channel Data_Ch : Payload_Ptr capacity 1;

   task Sender with Priority = 10
      Toggle : Boolean = False;

      loop
         declare
            Item : Payload_Ptr;
         begin
            if Toggle
               Item = new ((Value = 1) as Payload);
            else
               Item = new ((Value = 0) as Payload);

            send Data_Ch, Item;
            if Item == null
               delay 0.001;
            else
               delay 0.002;

         end;
         Toggle = not Toggle;



   task Receiver with Priority = 10

      loop
         declare
            Item : Payload_Ptr;
         begin
            receive Data_Ch, Item;
            if Item != null and then Item.all.Value == 0
               delay 0.001;
            else
               delay 0.002;

         end;




