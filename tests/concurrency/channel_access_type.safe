-- Test: channel_access_type
-- Description: Channel element types shall not be access types.
--   Access-typed channel declarations are rejected at the declaration site.
-- Expected: REJECT source_frontend_error

package Channel_Access_Type is

   type Payload_Value is range 0 to 1;

   type Payload is record
      Value : Payload_Value;
   end record;

   type Payload_Ptr is access Payload;

   channel Data_Ch : Payload_Ptr capacity 1;

   task Sender with Priority = 10 is
      Toggle : Boolean = False;
   begin
      loop
         declare
            Item : Payload_Ptr;
         begin
            if Toggle then
               Item = new ((Value = 1) as Payload);
            else
               Item = new ((Value = 0) as Payload);
            end if;
            send Data_Ch, Item;
            if Item == null then
               delay 0.001;
            else
               delay 0.002;
            end if;
         end;
         Toggle = not Toggle;
      end loop;
   end Sender;

   task Receiver with Priority = 10 is
   begin
      loop
         declare
            Item : Payload_Ptr;
         begin
            receive Data_Ch, Item;
            if Item != null and then Item.all.Value == 0 then
               delay 0.001;
            else
               delay 0.002;
            end if;
         end;
      end loop;
   end Receiver;

end Channel_Access_Type;
