-- Test: select_with_delay
-- Description: Select statement with one channel arm and one delay arm.
--   The worker waits on a channel receive arm and falls back to a relative
--   delay arm when no channel input is ready.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.4.p33:7a94ab51
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.4.p38:35ed84d9
-- Expected: ACCEPT

package select_with_delay

   type message is range 0 to 100;

   channel msg_ch : message capacity 1;

   task producer with Priority = 10

      loop
         delay 0.01;



   task poller with Priority = 10

      loop
         select
            when item : message from msg_ch
               if item > 0
                  delay 0.001;
               else
                  delay 0.001;

         or
            delay 0.05
               delay 0.001;





