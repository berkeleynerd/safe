-- Test: channel_ceiling_priority
-- Description: Channel ceiling summary uses transitive task access.
--   Two tasks with explicit priorities access the same channel through a
--   helper subprogram; the local Bronze ceiling should use the max priority.
-- Expected: ACCEPT

package channel_ceiling_priority

   subtype message is integer (0 to 1_000)
   subtype send_state is integer (0 to 1)

   channel data_ch : message capacity 2

   function push (value : message; status : mut send_state)
      sent : boolean = false
      previous_status : send_state = status

      send data_ch, value, sent
      if sent
         status = 1
      else
         status = previous_status

   task fast with priority = 20
      next : message = 0
      status : send_state = 0

      loop
         status = 0
         push (next, status)
         if status == 0
            delay 0.001
         if next < 1_000
            next = next + 1
         else
            next = 0

   task slow with priority = 10
      next : message = 100
      status : send_state = 0

      loop
         status = 0
         push (next, status)
         if status == 0
            delay 0.001
         if next < 1_000
            next = next + 1
         else
            next = 100
