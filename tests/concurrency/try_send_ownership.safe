-- Test: try_send_ownership
-- Description: Ownership-through-channels is excluded from the language.
--   Access-typed channel declarations are rejected before try_send semantics
--   are analyzed.
-- Expected: REJECT source_frontend_error

package Try_Send_Ownership

   type Payload is record
      Id    : Natural;
      Value : Integer;


   type Payload_Ptr is access Payload;

   channel Data_Ch : Payload_Ptr capacity 2;

   task Sender
      P       : Payload_Ptr;
      Success : Boolean;
      Counter : Natural = 0;

      loop
         P = new ((Id = Counter, Value = Counter * 10) as Payload);
         try_send Data_Ch, P, Success;
         if Success
         else
            P.all.Value = P.all.Value + 1;
            send Data_Ch, P;

         Counter = Counter + 1;
         if Counter > 1_000_000
            Counter = 0;




   task Receiver

      loop
         Item : Payload_Ptr;
         receive Data_Ch, Item;
         if Item != null
            Item.all.Value = 0;




