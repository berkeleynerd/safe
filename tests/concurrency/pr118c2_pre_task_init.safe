package pr118c2_pre_task_init

   subtype counter is integer (0 to 41)
   subtype send_state is integer (0 to 1)
   channel start_ch : counter capacity 1

   function seed_start (status : mut send_state)
      sent : boolean = false
      previous_status : send_state = status

      send start_ch, 41, sent
      if sent
         status = 1
      else
         status = previous_status

   initial_status : send_state = 0
   seed_marker : counter = 0

   task worker with priority = 10, sends start_ch, receives start_ch
      sent : boolean = false
      loop
         receive start_ch, start : counter
         print (start)
         send start_ch, start, sent
         if sent
            delay 0.05
         else
            delay 0.01

   seed_start (initial_status)
   seed_marker = counter (41 * initial_status)
