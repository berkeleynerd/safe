-- Test: task_priority_delay
-- Description: Task with explicit priority and relative delay.
--   A local task uses an explicit Priority aspect and a relative delay
--   inside its required outer loop body.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.1.p5:4e4afebc
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.6.p53:897d5577
-- Expected: ACCEPT

package task_priority_delay

   task worker with Priority = 5
      ticks : natural = 0;

      loop
         delay 0.25;
         ticks = ticks + 1;
         if ticks > 1_000
            ticks = 0;





