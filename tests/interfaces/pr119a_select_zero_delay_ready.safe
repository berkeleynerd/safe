package pr119a_select_zero_delay_ready

   subtype message is integer (0 to 10)

   channel msg_ch : message capacity 1
   result : integer = 0
   sent : boolean = false

   send msg_ch, 4, sent

   if sent
      select
         when item : message from msg_ch
            result = item
      or
         delay 0.0
            result = 9
   else
      result = 8

   print (result)
