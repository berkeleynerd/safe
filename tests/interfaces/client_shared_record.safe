with provider_shared_record;

package client_shared_record

   function total returns integer
      snapshot : provider_shared_record.settings = provider_shared_record.cfg;

      provider_shared_record.cfg.count = 5;
      provider_shared_record.cfg.nested.depth = 7;
      provider_shared_record.cfg = (count = 8, nested = (depth = 9));

      if snapshot.count == 1
         if provider_shared_record.cfg.count == 8
            if provider_shared_record.cfg.nested.depth == 9
               return 1;
      return 0;
