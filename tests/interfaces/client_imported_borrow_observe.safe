with Provider_Imported_Call_Ownership;

package Client_Imported_Borrow_Observe is

   function Run is
      Owner : Provider_Imported_Call_Ownership.Payload_Ptr =
        new ((Value = 5) as Provider_Imported_Call_Ownership.Payload);
      Seen  : Integer;
   begin
      Provider_Imported_Call_Ownership.Bump (Owner);
      Seen = Provider_Imported_Call_Ownership.Read_Value (Owner);
      Owner.all.Value = Seen;
   end Run;

end Client_Imported_Borrow_Observe;
