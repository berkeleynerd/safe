package pr119a_select_prebuffered

   subtype message is integer (0 to 10)

   channel msg_ch : message capacity 1
   total : integer = 0
   sent : boolean = false

   send msg_ch, 3, sent

   if sent
      select
         when item : message from msg_ch
            total = item
   else
      total = 9

   print (total)
