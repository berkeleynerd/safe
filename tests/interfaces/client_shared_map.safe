with provider_shared_map;

package client_shared_map

   function total returns integer
      found : optional integer;
      removed : optional integer;

      set (provider_shared_map.cache, "one", 1);
      provider_shared_map.cache.set ("two", 2);
      found = provider_shared_map.cache.get ("two");
      removed = provider_shared_map.cache.remove ("one");

      if found.present
         if removed.present
            if found.value == 2
               if removed.value == 1
                  if not provider_shared_map.cache.contains ("one")
                     return 1;
      return 0;
