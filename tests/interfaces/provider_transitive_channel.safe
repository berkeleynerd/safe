package Provider_Transitive_Channel

   public type Message is range 0 to 10;
   public channel Data_Ch : Message capacity 4;

   task Worker with Priority = 12

      loop
         declare
            Item : Message = 0;
         begin
            receive Data_Ch, Item;
         end;



   function Push_Internal

      send Data_Ch, 1;


   public function Push

      Push_Internal;



