package pr1123e_shadowed_loop_item

   subtype point is integer (0 to 40)

   function stats returns integer
      var items : list of point = [10, 20]
      var sum : integer = 0

      for item of items
         sum = sum + item
         var item : integer = -1
         sum = sum + item
         item = item + 1
         sum = sum + item

      return sum

   print (stats)
