package pr344_shadowing_decl_blocks_suppression

   subtype tally is integer (0 to 10)

   function compute_total (use_shadow : boolean) returns integer
      var total : tally = 0

      if use_shadow
         var total : tally
         total = 1
         print (total)
      else
         total = 2

      return total

   print (compute_total (false))
