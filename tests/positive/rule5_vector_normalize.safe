-- Test: rule5_vector_normalize
-- Description: Vector scaling with a computed positive floating divisor.
--   The divisor starts at 1 and increments once for each strictly positive
--   component, so it is always finite, positive, and nonzero.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139:d50bc714
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139b:5e20032b
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139d:56f1f36b
-- Expected: ACCEPT

package Safe_Vector_Normalize

   type Component is digits 6 range 0.0 to 100.0;
   type Positive_Count is range 1 to 4;
   type Vector3 is record
      X : Component;
      Y : Component;
      Z : Component;


   function Normalize_X (Input : Vector3) returns Float
      Divisor : Positive_Count = 1;

      if Input.X > 0.0
         Divisor = Divisor + 1;

      if Input.Y > 0.0
         Divisor = Divisor + 1;

      if Input.Z > 0.0
         Divisor = Divisor + 1;

      return Float (Input.X) / Float (Divisor);



