-- Test: pr1162_empty_select_delay_arm
-- Description: Empty delay arms remain legal after source null removal.
-- Expected: ACCEPT

package pr1162_empty_select_delay_arm

   type message is range 0 to 10;

   channel msg_ch : message capacity 1;

   task poller

      loop
         select
            when item : message from msg_ch
               delay 0.001;
         or
            delay 0.05
