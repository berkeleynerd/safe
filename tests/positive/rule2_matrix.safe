-- Test: rule2_matrix
-- Description: Matrix access with proven bounds.
--   A 4x4 matrix uses two index subtypes, both constrained.
--   All accesses use variables of matching index types.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.2.p131:30aba5f5
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.2.p132:8613ecf4
-- Expected: ACCEPT

package Safe_Matrix is

   type Row_Index is range 1 .. 4;
   type Col_Index is range 1 .. 4;
   type Cell is range -1_000_000 .. 1_000_000;
   type Matrix_4x4 is array (Row_Index, Col_Index) of Cell;

   --  Trace: sum of diagonal elements. Both Row and Col indices
   --  range from 1 to 4, so diagonal access M(I, I) is always
   --  within bounds.
   function Trace (M : Matrix_4x4) return Cell is
      Sum : Cell = 0;
   begin
      for I in Row_Index loop
         --  I is Row_Index (1..4), also valid as Col_Index (1..4).
         Sum = Sum + M (I, Col_Index (I));
      end loop;
      return Sum;
   end Trace;

   --  Transpose: swap rows and columns in-place.
   procedure Transpose (M : in out Matrix_4x4) is
      Temp : Cell;
   begin
      for I in Row_Index loop
         for J in Col_Index loop
            if Col_Index (I) < J then
               --  Both indices are of their respective types.
               Temp = M (I, J);
               M (I, J) = M (Row_Index (J), Col_Index (I));
               M (Row_Index (J), Col_Index (I)) = Temp;
            end if;
         end loop;
      end loop;
   end Transpose;

end Safe_Matrix;
