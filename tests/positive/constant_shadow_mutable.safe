-- Test: constant_shadow_mutable
-- Description: Mutable shadowing declaration clears outer constant binding.
--   An inner mutable object with the same name as an outer constant must
--   remain writable after shadowing.
-- Expected: ACCEPT

package Constant_Shadow_Mutable

   Value : constant Integer = 1;

   function Update_Local

      declare
         Value : Integer = 0;
      begin
         Value = 2;
      end;



