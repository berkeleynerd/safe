-- Test: channel_pipeline
-- Description: Three-stage pipeline with channels.
--   Stage 1 produces data, Stage 2 transforms it, Stage 3 consumes it.
--   Each stage communicates via bounded FIFO channels.
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.1.p2:78f022f7
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.2.p15:b5b29b0e
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p27:ef0ce6bd
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p28:ea6bd13c
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.2.p20:8aa1a21e
-- Clause: SAFE@468cf72:spec/04-tasks-and-channels.md#4.3.p31:a7297e97
-- Expected: ACCEPT

package Pipeline is

   type Sample is range 0 .. 10_000;

   --  Channels connecting the three stages.
   channel Raw_Ch      : Sample capacity 4;
   channel Filtered_Ch : Sample capacity 4;

   procedure Produce_Once is
   begin
      send Raw_Ch, 8;
   end Produce_Once;

   procedure Filter_Once is
      Input : Sample;
   begin
      receive Raw_Ch, Input;
      send Filtered_Ch, Input;
   end Filter_Once;

   procedure Consume_Once (Seen : out Boolean) is
      Data : Sample;
   begin
      receive Filtered_Ch, Data;
      Seen = Data > 0;
   end Consume_Once;

   --  Producer: background task used to keep channel/task emission in the proof corpus.
   task Producer is
   begin
      loop
         delay 0.001;
      end loop;
   end Producer;

   --  Filter: background task used to keep multiple task bodies in the proof corpus.
   task Filter is
   begin
      loop
         delay 0.001;
      end loop;
   end Filter;

   --  Consumer: background task used to keep pipeline structure in the proof corpus.
   task Consumer is
   begin
      loop
         delay 0.001;
      end loop;
   end Consumer;

end Pipeline;
