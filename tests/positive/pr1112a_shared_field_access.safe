package pr1112a_shared_field_access

   subtype counter is integer (0 to 20)

   type mode is (idle, ready)

   type nested_state is record
      depth : counter

   type settings is record
      count  : counter
      status : mode
      label  : string (5)
      maybe  : optional counter
      nested : nested_state

   shared cfg : settings = (count = 1, status = idle, label = "hello", maybe = none, nested = (depth = 2))

   maybe_now : optional counter
   count_now : counter
   status_now : mode
   label_now : string (5)
   nested_now : nested_state

   maybe_now = cfg.maybe
   count_now = cfg.count
   status_now = cfg.status
   label_now = cfg.label
   nested_now = cfg.nested

   if not maybe_now.present and then count_now == 1 and then status_now == idle and then label_now.length == 5 and then nested_now.depth == 2
      print (1)
   else
      print (0)
