-- Test: rule3_modulo
-- Description: Modular arithmetic with provably nonzero divisor.
--   Uses the mod operator with a positive constant or a guarded variable.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.3.p133:0610d951
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.3.p134:90a17a3b
-- Expected: ACCEPT

package safe_modulo

   subtype angle is integer (0 to 359)
   subtype wide_angle is integer (0 to 10_000)

   --  Normalize_Angle: wraps an angle to 0..359 using mod 360.
   --  The literal 360 is provably nonzero.
   function normalize_angle (raw : wide_angle) returns angle

      --  360 is a nonzero literal. Provably nonzero.
      return angle (raw mod 360)

   --  Ring_Index: maps a counter to a circular buffer position.
   --  Buffer_Size is constrained to 1..256.
   subtype buffer_size is integer (1 to 256)

   function ring_index (counter : integer;
                        size    : buffer_size) returns integer

      --  Size is of type Buffer_Size (1..256), provably nonzero.
      return counter mod integer (size)

