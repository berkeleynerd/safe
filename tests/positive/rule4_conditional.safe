-- Test: rule4_conditional
-- Description: Conditional dereference with null guard on inferred references.
-- Expected: ACCEPT

package safe_conditional

   subtype config_value is integer (0 to 1000)

   type config_box is record
      value : config_value
      next : config_box

   function max_of_two (a, b : config_box) returns config_value

      if a != null and then b != null
         if a.value >= b.value
            return a.value
         else
            return b.value

      else if a != null
         return a.value
      else if b != null
         return b.value
      else
         return 0
