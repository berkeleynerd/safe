-- Test: constant_access_deref_write
-- Description: Constant inferred-reference bindings remain readable.
--   A constant binding to a reference root can still be read through its
--   implicit designated object.
-- Expected: ACCEPT

package constant_access_deref_write

   type payload is record
      value : integer
      next : payload

   function read_through_constant returns integer
      ptr : constant not null payload = (value = 1, next = null)

      return ptr.value
