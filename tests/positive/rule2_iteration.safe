-- Test: rule2_iteration
-- Description: Array iteration with index provably in bounds.
--   The for loop variable ranges over the array's index subtype,
--   guaranteeing every access is safe.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.2.p131:30aba5f5
-- Expected: ACCEPT

package Safe_Iteration

   type Slot is range 0 to 15;
   type Value is range 0 to 1000;
   type Register_Bank is array (Slot) of Value;

   --  Find_Max: iterates over all slots to find the maximum value.
   --  The loop variable I has type Slot (0..15), matching the
   --  array index bounds exactly.
   function Find_Max (Bank : Register_Bank) returns Value
      Max_Val : Value = Bank (0);

      for I in Slot
         --  I is of type Slot (0..15), same as array index. In bounds.
         if Bank (I) > Max_Val
            Max_Val = Bank (I);


      return Max_Val;


   --  Zero_All: sets every element to zero.
   function Zero_All (Bank : out Register_Bank)

      for I in Slot
         Bank (I) = 0;




