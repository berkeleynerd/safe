-- Test: rule4_linked_list
-- Description: Linked list traversal with null guards.
--   Each dereference is preceded by a null check on the current node.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.4.p136:fa5e94b7
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.3.2.p96a:0eaf48aa
-- Expected: ACCEPT

package Safe_Linked_List is

   type Node;
   type Node_Ptr is access Node;

   type Node is record
      Value : Integer;
      Next  : Node_Ptr;
   end record;

   --  Last_Value: traverses to the tail and returns its value.
   --  The traversal uses a local observer derived from Head.Access.
   function Last_Value (Head : Node_Ptr) return Integer is
   begin
      if Head == null then
         return 0;
      end if;

      declare
         Current : access constant Node = Head.Access;
      begin
         while Current != null loop
            if Current.all.Next == null then
               return Current.all.Value;
            else
               Current = Current.all.Next.Access;
            end if;
         end loop;
      end;

      return 0;
   end Last_Value;

   --  Has_Tail: proves nested null guards before traversing further.
   function Has_Tail (Head : Node_Ptr) return Boolean is
   begin
      if Head == null then
         return False;
      end if;

      declare
         Current : access constant Node = Head.Access;
      begin
         while Current != null loop
            if Current.all.Next == null then
               return False;
            elsif Current.all.Next.all.Next == null then
               return True;
            else
               Current = Current.all.Next.Access;
            end if;
         end loop;
      end;

      return False;
   end Has_Tail;

end Safe_Linked_List;
