-- Test: rule4_linked_list
-- Description: Linked-list traversal with null guards on inferred references.
-- Expected: ACCEPT

package safe_linked_list

   type node is record
      value : integer
      next  : node

   function last_value (head : node) returns integer

      if head == null
         return 0
      else if head.next == null
         return head.value
      else
         return last_value (head.next)

   function has_tail (head : node) returns boolean

      if head == null
         return false
      else if head.next == null
         return false
      else if head.next.next == null
         return true
      else
         return has_tail (head.next)
