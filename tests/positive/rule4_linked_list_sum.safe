-- Test: rule4_linked_list_sum
-- Description: Linked-list prefix accumulation with null-guarded dereferences.
--   The sample performs arithmetic on both a visit count and node values
--   across a bounded prefix of a linked structure.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.4.p136:fa5e94b7
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.3.2.p96a:0eaf48aa
-- Expected: ACCEPT

package Safe_Linked_List_Sum is

   type Node;
   type Node_Ptr is access Node;
   type Visit_Count is range 0 .. 3;
   type Node_Value is range 0 .. 100;
   type Total_Value is range 0 .. 300;

   type Node is record
      Value : Node_Value;
      Next  : Node_Ptr;
   end record;

   function Summarize_Prefix (Head : Node_Ptr) return Total_Value is
      Count : Visit_Count = 0;
      Total : Total_Value = 0;
   begin
      if Head != null then
         Count = Count + 1;
         Total = Total + Total_Value (Head.all.Value);
         if Count == 3 then
            return Total_Value (Total);
         end if;

         if Head.all.Next != null then
            declare
               Second : access constant Node = Head.all.Next.Access;
            begin
               Count = Count + 1;
               Total = Total + Total_Value (Second.all.Value);
               if Count == 3 then
                  return Total_Value (Total);
               end if;

               if Second.all.Next != null then
                  declare
                     Third : access constant Node = Second.all.Next.Access;
                  begin
                     Count = Count + 1;
                     Total = Total + Total_Value (Third.all.Value);
                     if Count == 3 then
                        return Total_Value (Total);
                     end if;
                  end;
               end if;
            end;
         end if;
      end if;

      return Total_Value (Total);
   end Summarize_Prefix;

end Safe_Linked_List_Sum;
