-- Test: pr113_variant_guard
-- Description: Integer-driven variant fields guarded by if and strict case.
-- Expected: ACCEPT

package pr113_variant_guard

   type packet (kind : integer = 0) is
      record
         case kind
            when 0
               alpha : integer
            when others
               beta : integer

   function read_alpha (p : packet) returns integer

      if p.kind == 0
         return p.alpha

      return 0

   function read_alpha_with_case (p : packet) returns integer

      case p.kind
         when 0
            return p.alpha

         when others
            return 0
