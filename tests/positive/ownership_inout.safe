-- Test: ownership_inout
-- Description: Passing an inferred-reference owner by `mut`.
-- Expected: ACCEPT

package ownership_inout

   type payload is record
      value : integer
      next : payload

   function consume (ref : mut payload)
      ref.value = 6

   function use_inout
      owner : not null payload = (value = 5, next = null)

      consume (owner)
