-- Test: ownership_inout
-- Description: Passing an owner by in out without using it afterward.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.3.2.p96a:0eaf48aa
-- Expected: ACCEPT

package Ownership_Inout is

   type Payload is record
      Value : Integer;
   end record;

   type Payload_Ptr is access Payload;

   function Consume (Ref : in out Payload_Ptr) is
   begin
      null;
   end Consume;

   function Use_Inout is
      Owner : Payload_Ptr = new ((Value = 5) as Payload);
   begin
      Consume (Owner);
   end Use_Inout;

end Ownership_Inout;
