-- Test: constant_task_priority
-- Description: Local integer constant used in a task priority aspect.
-- Expected: ACCEPT

package Constant_Task_Priority is

   Worker_Priority : constant Integer = 5;

   task Worker with Priority = Worker_Priority is
      Counter : Natural = 0;
   begin
      loop
         Counter = Counter + 1;
         if Counter > 10 then
            Counter = 0;
         end if;
      end loop;
   end Worker;

end Constant_Task_Priority;
