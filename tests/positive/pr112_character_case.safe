-- Test: pr112_character_case
-- Description: Single-character strings and integer-based case.
-- Expected: ACCEPT

package pr112_character_case

   marker : constant string = 'A'
   fallback : constant string = "needs work"

   function grade_message (grade : integer (0 to 2)) returns string

      case grade
         when 0
            return "excellent"

         when 1
            return "good"

         when others
            return fallback
