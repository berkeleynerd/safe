-- Test: pr09_emitter_discriminant
-- Description: Historical PR09a discriminant-surface regression fixture.
--   The path now lives under tests/positive so future fixture-metadata
--   tooling does not misclassify it as a rejecting negative case.
--   The current boolean-discriminant subset is emitted and compile-validated.
-- Expected: ACCEPT

package pr09_emitter_discriminant
   type emitter_result (ok : boolean = false) is record
      case ok
         when true
            value : integer;
         when false
            error_code : integer;


