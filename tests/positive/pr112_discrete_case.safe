-- Test: pr112_discrete_case
-- Description: Boolean and integer case statements plus direct string returns.
-- Expected: ACCEPT

package pr112_discrete_case

   function flag_value (flag : in boolean) returns integer

      case flag
         when true
            return 1;

         when others
            return 0;

   function opcode_name (opcode : in integer) returns string

      case opcode
         when -1
            return "reset";

         when 0
            return "nop";

         when 1
            return "load";

         when others
            return "unknown";

