-- Test: emitter_surface_record
-- Description: Minimal PR09 surface fixture for package skeleton emission.
--   Exercises deterministic spec/body splitting, simple record declarations,
--   object declarations, and literal/identifier returns without arithmetic.
-- Expected: ACCEPT

package Emitter_Surface_Record is

   type Counter is range 0 to 10;

   type Pair is record
      Left  : Counter;
      Right : Counter;
   end record;

   Seed : Counter = 3;

   function Current returns Counter is
      Value : Counter = Seed;
   begin
      return Value;
   end Current;

end Emitter_Surface_Record;
