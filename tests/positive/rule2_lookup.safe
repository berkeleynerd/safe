-- Test: rule2_lookup
-- Description: Array lookup with proven index bounds.
--   The index is constrained by the array's index subtype,
--   so every access is provably within bounds.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.2.p131:30aba5f5
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.2.p132:8613ecf4
-- Expected: ACCEPT

package safe_lookup

   type sensor_id is range 1 to 8;
   type calibration is range -100 to 100;
   type cal_table is array (sensor_id) of calibration;

   --  Lookup: retrieves calibration value for a given sensor.
   --  The index type Sensor_Id is 1..8, matching the array bounds.
   function lookup (table : cal_table; id : sensor_id) returns calibration

      --  Index Id is of type Sensor_Id (1..8), which matches the
      --  array index range exactly. Provably within bounds.
      return table (id);

   --  Lookup_With_Default: safe lookup with a clamped index.
   function lookup_with_default (table : cal_table;
                                 raw_id : integer) returns calibration

      if raw_id >= 1 and then raw_id <= 8
         --  Index Raw_Id is proven in 1..8 by the guard.
         return table (sensor_id (raw_id));
      else
         return 0;

