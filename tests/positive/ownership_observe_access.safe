-- Test: ownership_observe_access
-- Description: Immutable borrow uses ordinary parameter syntax in PR11.8e.
-- Expected: ACCEPT

package ownership_observe_access

   type config is record
      rate : integer
      next : config

   function read_with_observer (observer : config) returns integer
      return observer.rate

   function read_with_local_observer
      owner : not null config = (rate = 100, next = null)
      rate  : integer

      rate = read_with_observer (owner)
