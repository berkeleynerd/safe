-- Test: rule4_optional
-- Description: Optional inferred-reference access with null checks.
-- Expected: ACCEPT

package safe_optional

   subtype value is integer (0 to 10_000)

   type value_box is record
      stored : value
      next   : value_box

   function get_or_default (p : value_box;
                            default : value) returns value

      if p != null
         return p.stored
      else
         return default

   function has_value (p : value_box) returns boolean

      return p != null
