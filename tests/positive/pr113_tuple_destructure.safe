-- Test: pr113_tuple_destructure
-- Description: Tuple returns, tuple field access, and local destructuring.
-- Expected: ACCEPT

package PR113_Tuple_Destructure

   function Lookup (Flag : in Boolean) returns (Boolean, Integer)

      if Flag
         return (True, 7);

      return (False, 0);

   function Read_Second returns Integer
      Direct : (Boolean, Integer) = Lookup (False);

      (Found, Value) : (Boolean, Integer) = Lookup (True);
      if Found
         return Value;

      return Direct.2;

