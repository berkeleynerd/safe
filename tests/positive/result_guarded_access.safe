-- Test: result_guarded_access
-- Description: Discriminated result with guarded variant field access.
--   The conditional branch on R.OK establishes the discriminant value,
--   making R.Value and R.Error accessible in their respective branches.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.12.p148
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.6.p139f
-- Expected: ACCEPT

package Result_Guarded_Access is

   type Error_Code is range 0 to 255;

   type Parse_Result (OK : Boolean = False) is record
      case OK is
         when True  then Value : Integer;
         when False then Error : Error_Code;
      end case;
   end record;

   function Try_Parse (Input : Integer) returns Parse_Result is
   begin
      if Input >= 0 then
         return (OK = True, Value = Input);
      else
         return (OK = False, Error = 1);
      end if;
   end Try_Parse;

   --  Get_Or_Default: guarded access to variant fields.
   --  The branch on R.OK establishes the discriminant in each arm.
   function Get_Or_Default (Input : Integer;
                            Default : Integer) returns Integer is
      R : Parse_Result = Try_Parse (Input);
   begin
      if R.OK then
         return R.Value;   -- legal: R.OK = True established
      else
         return Default;
      end if;
   end Get_Or_Default;

end Result_Guarded_Access;
