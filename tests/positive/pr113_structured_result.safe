-- Test: pr113_structured_result
-- Description: Builtin result plus tuple-based structured return conventions.
-- Expected: ACCEPT

package pr113_structured_result

   function reject (msg : string) returns result

      return fail (msg)

   function parse (input : integer) returns (result, integer)

      if input >= 0
         return (ok (), input)

      return (reject ("negative"), 0)

   function legacy (input : integer) returns (boolean, integer)

      if input >= 0
         return (true, input)

      return (false, 0)
