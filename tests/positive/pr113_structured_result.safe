-- Test: pr113_structured_result
-- Description: Builtin result plus tuple-based structured return conventions.
-- Expected: ACCEPT

package PR113_Structured_Result

   function Reject (Msg : in String) returns result

      return fail (Msg);

   function Parse (Input : in Integer) returns (result, Integer)

      if Input >= 0
         return (ok (), Input);

      return (Reject ("negative"), 0);

   function Legacy (Input : in Integer) returns (Boolean, Integer)

      if Input >= 0
         return (True, Input);

      return (False, 0);

