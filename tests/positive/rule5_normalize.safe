-- Test: rule5_normalize
-- Description: Bounded floating-point normalization by a fixed scale.
--   The divisor is a positive nonzero literal, so division is safe.
--   Bounded inputs yield bounded finite results at the narrowing point.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139:d50bc714
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139b:5e20032b
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139d:56f1f36b
-- Expected: ACCEPT

package Vector_Normalize is

   type Sample is digits 6 range -1000.0 .. 1000.0;
   type Ratio is digits 6 range -1.0 .. 1.0;

   --  Normalize: divide by a fixed nonzero bound.
   --  Input range: -1000.0 .. 1000.0
   --  Division by 1000.0 is safe and yields a result in -1.0 .. 1.0.
   --  No NaN or infinity can arise from bounded finite inputs.
   function Normalize (Value : Sample) return Ratio is
      Result : Long_Float;
   begin
      Result = Long_Float (Value) / 1000.0;
      return Ratio (Result);
   end Normalize;

end Vector_Normalize;
