-- Test: rule1_accumulate
-- Description: Loop accumulation with range narrowing.
--   Accumulates values from an array into a bounded sum, proving
--   that the intermediate total stays within range at each iteration.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.1.p126:812b54a8
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.1.p127:d5d93439
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.1.p129:9f3b1394
-- Expected: ACCEPT

package accumulator

   subtype small_int is integer (0 to 100)
   subtype index is integer (1 to 20)
   type values is array (index) of small_int

   --  Total_Range: The accumulated sum of up to 20 values each in 0..100
   --  is at most 2000. We declare a type to hold that.
   subtype total_range is integer (0 to 2000)

   --  Accumulate: sum all elements of the array.
   --  Loop invariant ensures Sum stays in 0 .. I * 100.
   function accumulate (data : values) returns total_range
      sum : total_range = 0

      for i in index
         --  Wide intermediate: Sum + Data(I) is at most 2000 + 100 = 2100
         --  but Sum is bounded by (I-1)*100 and Data(I) by 100,
         --  so Sum + Data(I) <= I*100 <= 2000, within Total_Range.
         sum = sum + total_range (data (i))

      --  Narrowing point (return): Sum is in 0..2000.
      return sum

