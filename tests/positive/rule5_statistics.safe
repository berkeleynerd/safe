-- Test: rule5_statistics
-- Description: Mean and variance computation with FP safety.
--   Input data is bounded, so sums and squares are finite.
--   Division by count is safe (count >= 1). Result is finite
--   at narrowing points.
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139d:56f1f36b
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.5.p139b:5e20032b
-- Clause: SAFE@468cf72:spec/02-restrictions.md#2.8.3.p133:0610d951
-- Expected: ACCEPT

package Safe_Statistics

   type Sample_Index is range 1 to 100;
   type Sample_Value is digits 6 range -1000.0 to 1000.0;
   type Sample_Array is array (Sample_Index) of Sample_Value;

   --  Mean: online average update with a provably nonzero typed divisor.
   --  At each step the new mean is an interpolation between the previous
   --  mean and the new sample, so it stays within -1000..1000.
   function Mean (Data : Sample_Array) returns Sample_Value
      Running_Mean : Sample_Value = 0.0;

      for I in Sample_Index
         Running_Mean = Sample_Value (
            Long_Float (Running_Mean)
            + (Long_Float (Data (I)) - Long_Float (Running_Mean))
            / Long_Float (I)
         );

      return Running_Mean;


   --  Variance: average of squared deviations from the mean.
   function Variance (Data : Sample_Array) returns Long_Float
      M       : Long_Float;
      Sum_Sq  : Long_Float = 0.0;
      Diff    : Long_Float;

      M = Long_Float (Mean (Data));
      for I in Sample_Index
         Diff = Long_Float (Data (I)) - M;
         --  Diff is in -2000..2000, Diff*Diff in 0..4_000_000 (finite).
         Sum_Sq = Sum_Sq + Diff * Diff;

      --  Sum_Sq is at most 100 * 4_000_000 = 400_000_000 (finite).
      --  Division by 100.0 (nonzero) yields finite result.
      return Sum_Sq / 100.0;

